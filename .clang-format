SpacesBeforeTrailingComments: 2
IncludeCategories:
  - Regex: "^<readline/.*>$"
    Priority: 1
    SortPriority: 2
  - Regex: "^<.*>$"
    Priority: 1
    SortPriority: 1
  - Regex: '^".*"$'
    Priority: 2
    SortPriority: 3
IncludeBlocks: Regroup
SortIncludes: true
AllowShortBlocksOnASingleLine: Empty
AllowShortFunctionsOnASingleLine: Empty
BreakBeforeBinaryOperators: NonAssignment
